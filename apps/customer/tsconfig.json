{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@prayana/shared-types": [
        "../../packages/shared-types/src"
      ],
      "@prayana/shared-utils": [
        "../../packages/shared-utils/src"
      ],
      "@prayana/shared-stores": [
        "../../packages/shared-stores/src"
      ],
      "@prayana/shared-services": [
        "../../packages/shared-services/src"
      ],
      "@prayana/shared-hooks": [
        "../../packages/shared-hooks/src"
      ],
      "@prayana/shared-ui": [
        "../../packages/shared-ui/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
